# .env — Raspberry Pi 3 Bus Node
# Edit BEFORE starting the service

# ── Identity ──────────────────────────────────────────────────────────────────
COUNTRY_CODE=GQ
REGION_NAME=Bioko

# ── Server (intranet — do NOT change to an internet URL) ──────────────────────
# bioko-server resolves via relay node dnsmasq at every terminal
SERVER_URL=http://bioko-server:5000
API_KEY=BIOKO_BUS_KEY_CHANGE_ME

# ── Audio ─────────────────────────────────────────────────────────────────────
AUDIO_LANGUAGE=es

# ── Timing ────────────────────────────────────────────────────────────────────
HEARTBEAT_INTERVAL=30
SERVER_TIMEOUT=8

# ── Engine health ─────────────────────────────────────────────────────────────
OBD_PORT=/dev/ttyUSB0
OBD_BAUDRATE=38400
ENGINE_POLL_INTERVAL=2.0
ADC_SPI_BUS=0
ADC_SPI_DEVICE=0
ADC_VREF=3.3
